# Real-data UI E2E configuration.
# Copy to .env.e2e.local and keep it private.
E2E_BACKEND_URL=http://localhost:8080/api/v1
E2E_WS_URL=http://localhost:8080/ws
E2E_FRONTEND_URL=http://localhost:5173

E2E_PASSWORD=123456
E2E_MANGAKA_EMAIL=HuyMangaka@gmail.com
E2E_ASSISTANT_EMAIL=HuyAssistant@gmail.com
E2E_TANTOU_EMAIL=HuyTantou@gmail.com
E2E_BOARD_EMAIL=HuyBoard1@gmail.com
E2E_ADMIN_EMAIL=admin@studio.com

# true runs invisibly; false opens the browser.
E2E_HEADLESS=true
E2E_TIMEOUT_MS=45000
E2E_UPLOAD_TIMEOUT_MS=120000

# Optional: path to Chrome/Edge if automatic detection fails.
# E2E_BROWSER_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional: the Node test starts this JAR when port 8080 is not already reachable.
# E2E_BACKEND_JAR=..\SWP_BACKEND\target\backend-0.0.1-SNAPSHOT.jar
